<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d %-5p [%t] %c - %m%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <AsyncRoot level="${sys:logging.level:-INFO}">
      <AppenderRef ref="Console"/>
    </AsyncRoot>
  </Loggers>
</Configuration>
